        "Sequential Ops",
        "Max Path"
      ],
      "rows": [
        [
          "Self-Attention",
          "O(n²·d)",
          "O(1)",
          "O(1)"
        ],
        [
          "Recurrent",
          "O(n·d²)",
          "O(n)",
          "O(n)"
        ],
        [
          "Convolutional",
          "O(k·n·d²)",
          "O(1)",
          "O(log_k n)"
        ],
        [
          "Restricted Attn",
          "O(r·n·d)",
          "O(1)",
          "O(n/r)"
        ]
      ]
    },
    {
      "type": "bars",
